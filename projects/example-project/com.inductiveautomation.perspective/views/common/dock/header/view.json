{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 56
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "basis": "0",
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "page.props.title"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "color": "#FFFFFF",
            "fontSize": "16px",
            "fontWeight": 600
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "page": "/overview"
              },
              "scope": "C",
              "type": "nav"
            }
          }
        },
        "meta": {
          "name": "navOverview"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "props": {
          "text": "Overview"
        },
        "type": "ia.input.button"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "page": "/refrigeration"
              },
              "scope": "C",
              "type": "nav"
            }
          }
        },
        "meta": {
          "name": "navRefrigeration"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "props": {
          "text": "Refrigeration"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "backgroundColor": "#5A5A5A",
        "gap": "15px",
        "padding": "14px"
      }
    },
    "type": "ia.container.flex"
  }
}