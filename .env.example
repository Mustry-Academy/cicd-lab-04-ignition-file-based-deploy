# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.
#
# This lab runs THREE Ignition gateways (local / dev / prod). Each gateway has
# its own admin credentials and its own API key. Local credentials are used
# at first login; dev/prod credentials are only needed when you click into
# those gateways' UIs.
#
# Leave the IGNITION_API_KEY_* lines EMPTY: scripts/setup.sh (via
# scripts/generate-api-keys.sh) generates a unique key per gateway on first
# run, fills the value in here, and writes the matching token resource (the
# gateway stores only the SHA-256 hash of the secret) into that gateway's
# config tree. Nothing key-related is committed — the token paths are
# gitignored and the deploy workflows spare them on the gateway — so every
# clone gets its own working credentials, and this file never holds a real
# secret. For CI, copy the generated IGNITION_API_KEY_DEV / _PROD values
# into GitHub environment secrets named IGNITION_API_KEY on the
# lab-gateway-dev / lab-gateway-prod environments. See README.md.

# ---- Local gateway (http://localhost:8088) ------------------------------
GATEWAY_ADMIN_USERNAME_LOCAL=admin
GATEWAY_ADMIN_PASSWORD_LOCAL=password
IGNITION_API_KEY_LOCAL=

# ---- Dev gateway (http://localhost:8089) — deploy.yml target ------------
GATEWAY_ADMIN_USERNAME_DEV=admin
GATEWAY_ADMIN_PASSWORD_DEV=password
IGNITION_API_KEY_DEV=

# ---- Prod gateway (http://localhost:8090) — release.yml target ----------
GATEWAY_ADMIN_USERNAME_PROD=admin
GATEWAY_ADMIN_PASSWORD_PROD=password
IGNITION_API_KEY_PROD=

# ---- Backward-compat single key (optional) ------------------------------
# Older scripts/CI workflows that don't set a per-gateway key fall back to
# this. You can leave it unset; scan.sh will pick the right
# IGNITION_API_KEY_<GATEWAY> based on the --gateway flag.
# IGNITION_API_KEY=

# ---- Shared TimescaleDB sidecar ------------------------------------------
# One Postgres instance, three databases (ignition_loc, ignition_dev,
# ignition_prd). These creds are the superuser; create per-env users via
# the gateway DB connection UI if you want isolation.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=ignition

# ---- GitHub Actions self-hosted runner ----------------------------------
# Auto-starts as part of `docker compose up -d`. The runner uses RUNNER_GITHUB_PAT
# (a GitHub Personal Access Token with `repo` scope) to fetch its own registration
# token, so you don't have to generate one manually. Both vars MUST be set for the
# runner container to register; otherwise it'll restart-loop with a 401 in its logs.
#
# Create the PAT once, here — Labs 05 and 06 reuse the same token:
#   github.com/settings/tokens → Generate new token (classic) → tick `repo` →
#   Generate → copy the ghp_... value into RUNNER_GITHUB_PAT below.
#
# RUNNER_REPO_URL is your fork (not the upstream mustry-academy repo).
# RUNNER_GITHUB_PAT lives only in .env — never commit it.
RUNNER_REPO_URL=https://github.com/<your-github-user>/cicd-lab-04-ignition-file-based-deploy
RUNNER_GITHUB_PAT=ghp_replace-me-with-a-pat-that-has-repo-scope
RUNNER_NAME=lab04-runner
