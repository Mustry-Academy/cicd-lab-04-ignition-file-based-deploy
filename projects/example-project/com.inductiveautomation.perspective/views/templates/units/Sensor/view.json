{
  "custom": {},
  "params": {
    "instanceName": "Sensor 1"
  },
  "propConfig": {
    "params.instanceName": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 110,
      "width": 320
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Name"
            },
            "position": {
              "grow": 1,
              "shrink": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.instanceName"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "#1A1A1A",
                "fontSize": "14px",
                "fontWeight": 600
              },
              "text": "--"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "22px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "L"
            },
            "position": {
              "basis": "0",
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "#555555",
                "fontSize": "12px"
              },
              "text": "Temperature"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "V"
            },
            "position": {
              "basis": "80px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/Temperature\u0027), \u00270.##\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#1A1A1A",
                "fontSize": "12px",
                "fontWeight": 600,
                "textAlign": "right"
              },
              "text": "--"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "TempRow"
        },
        "position": {
          "basis": "20px",
          "shrink": 0
        },
        "props": {
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "L"
            },
            "position": {
              "basis": "0",
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "#555555",
                "fontSize": "12px"
              },
              "text": "Humidity"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "V"
            },
            "position": {
              "basis": "80px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/Humidity\u0027), \u00270.##\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#1A1A1A",
                "fontSize": "12px",
                "fontWeight": 600,
                "textAlign": "right"
              },
              "text": "--"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "HumRow"
        },
        "position": {
          "basis": "20px",
          "shrink": 0
        },
        "props": {
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#EDEDED",
        "borderColor": "#999999",
        "borderStyle": "solid",
        "borderWidth": "1px",
        "gap": "6px",
        "padding": "8px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}