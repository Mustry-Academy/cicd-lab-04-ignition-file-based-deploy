# .deployignore — patterns NOT to copy onto the gateway during a file-based deploy.
#
# Format: gitignore-style. One pattern per line. Blank lines and lines starting
# with `#` are ignored. Trailing slashes match directories.
#
# The deploy script reads this file and prunes the working tree before copying.
# Anything matched here exists in the repo but never lands on the gateway.

# Lab-only files that have nothing to do with the gateway runtime
README.md
LICENSE
.deployignore
.gitignore
.gitattributes
.env.example
.github/
docs/
exercises/
instructor-notes/
scripts/
tests/
third-party-modules/
db-init/
services/config/local/
# Per-instance identity (UUID, OPC-UA keystores, machine-local system props).
# Must never be copied onto another gateway — each instance owns its own.
services/config/resources/local/
# Per-gateway auth state: users.json carries the LOCAL gateway's admin
# password hash, and the identity provider is bound to that user source.
# Deploying these overwrites the target gateway's own admin user — instant
# lockout. These are untracked in git too; this entry protects manual deploys
# run from a working tree where the local gateway has written them.
services/config/resources/core/ignition/user-source/
services/config/resources/core/ignition/identity-provider/
# Dev/prod gateway state (bind mounts) — never part of a deploy payload
gateways/

# OS noise
.DS_Store
Thumbs.db

# Editor noise
.vscode/
.idea/
*.swp

# Compose / dev-only files
docker-compose.yaml
.env
