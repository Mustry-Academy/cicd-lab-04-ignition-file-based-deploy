{
  "custom": {},
  "params": {
    "instanceName": "Motor 1"
  },
  "propConfig": {
    "params.instanceName": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 130,
      "width": 170
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Status"
            },
            "position": {
              "basis": "14px",
              "shrink": 0
            },
            "propConfig": {
              "props.fill.paint": {
                "binding": {
                  "config": {
                    "expression": "if(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/HOA\u0027) \u003d 2, \u0027#1E8449\u0027, if(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/HOA\u0027) \u003d 1, \u0027#D4AC0D\u0027, if(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/HOA\u0027) \u003d 0, \u0027#8E8E8E\u0027, \u0027#CCCCCC\u0027)))"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "fill": {
                "paint": "#CCCCCC"
              },
              "stroke": {
                "paint": "#777777",
                "width": 1
              }
            },
            "type": "ia.shapes.ellipse"
          },
          {
            "meta": {
              "name": "Name"
            },
            "position": {
              "grow": 1,
              "shrink": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.instanceName"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "#1A1A1A",
                "fontSize": "14px",
                "fontWeight": 600
              },
              "text": "--"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "22px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "AmpsTank"
            },
            "position": {
              "basis": "20px",
              "shrink": 0
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "expression": "tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/Amps\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "max": 200,
              "min": 0,
              "tank": {
                "fill": {
                  "color": "#1F77B4"
                },
                "stroke": {
                  "color": "#999999"
                }
              },
              "value": 0,
              "valueRendering": "none"
            },
            "type": "ia.display.cylindrical-tank"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "L"
                    },
                    "position": {
                      "basis": "0",
                      "grow": 1,
                      "shrink": 0
                    },
                    "props": {
                      "style": {
                        "color": "#555555",
                        "fontSize": "12px"
                      },
                      "text": "Amps"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "V"
                    },
                    "position": {
                      "basis": "55px",
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "numberFormat(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/Amps\u0027), \u00270.##\u0027)"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "style": {
                        "color": "#1A1A1A",
                        "fontSize": "12px",
                        "fontWeight": 600,
                        "textAlign": "right"
                      },
                      "text": "--"
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "AmpsRow"
                },
                "position": {
                  "basis": "20px",
                  "shrink": 0
                },
                "props": {
                  "direction": "row",
                  "style": {
                    "gap": "8px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "L"
                    },
                    "position": {
                      "basis": "0",
                      "grow": 1,
                      "shrink": 0
                    },
                    "props": {
                      "style": {
                        "color": "#555555",
                        "fontSize": "12px"
                      },
                      "text": "HOA"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "V"
                    },
                    "position": {
                      "basis": "55px",
                      "shrink": 0
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "expression": "numberFormat(tag(\u0027[]Overview/\u0027 + {view.params.instanceName} + \u0027/HOA\u0027), \u00270.##\u0027)"
                          },
                          "type": "expr"
                        }
                      }
                    },
                    "props": {
                      "style": {
                        "color": "#1A1A1A",
                        "fontSize": "12px",
                        "fontWeight": 600,
                        "textAlign": "right"
                      },
                      "text": "--"
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "HOARow"
                },
                "position": {
                  "basis": "20px",
                  "shrink": 0
                },
                "props": {
                  "direction": "row",
                  "style": {
                    "gap": "8px"
                  }
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "Vals"
            },
            "position": {
              "grow": 1,
              "shrink": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "gap": "4px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Body"
        },
        "position": {
          "grow": 1,
          "shrink": 1
        },
        "props": {
          "direction": "row",
          "style": {
            "gap": "8px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#EDEDED",
        "borderColor": "#999999",
        "borderStyle": "solid",
        "borderWidth": "1px",
        "gap": "6px",
        "padding": "8px 12px"
      }
    },
    "type": "ia.container.flex"
  }
}